--- QUERY 1: OVERALL SOP SUMMARY ---
Name: SOP_Overall
Paste:

SELECT
    "SOP_Result" AS "SOP Status",
    COUNT(*) AS "Count",
    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 1) AS "Percentage"
FROM "Followups"
WHERE "Is_Excluded" = 'No'
GROUP BY "SOP_Result"
ORDER BY CASE "SOP_Result"
    WHEN 'PASS' THEN 1
    WHEN 'SCHEDULED' THEN 2
    WHEN 'FAIL' THEN 3
    WHEN 'SKIP' THEN 4
    WHEN 'NO NUMBER' THEN 5
    ELSE 6 END


--- QUERY 2: AGENT WISE SOP ---
Name: Agent_SOP
Paste:

SELECT
    "Followup Owner" AS "Agent",
    COUNT(*) AS "Total",
    SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) AS "PASS",
    SUM(CASE WHEN "SOP_Result" = 'FAIL' THEN 1 ELSE 0 END) AS "FAIL",
    SUM(CASE WHEN "SOP_Result" = 'FAIL' THEN "Required_Calls" - "Total Calls" ELSE 0 END) AS "Shortfall",
    ROUND(SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS "SOP %",
    CASE
        WHEN SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) >= 80 THEN 'A'
        WHEN SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) >= 60 THEN 'B'
        WHEN SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) >= 40 THEN 'C'
        ELSE 'D'
    END AS "Grade"
FROM "Followups"
WHERE "Is_Excluded" = 'No'
  AND "SOP_Result" NOT IN ('SKIP', 'NO NUMBER')
GROUP BY "Followup Owner"
ORDER BY "SOP %" DESC


--- QUERY 3: LEAD SOURCE_2 WISE SOP ---
Name: Source_SOP
Paste:

SELECT
    "Lead Source_2" AS "Lead Source",
    COUNT(*) AS "Total",
    SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) AS "PASS",
    SUM(CASE WHEN "SOP_Result" = 'FAIL' THEN 1 ELSE 0 END) AS "FAIL",
    SUM(CASE WHEN "SOP_Result" = 'FAIL' THEN "Required_Calls" - "Total Calls" ELSE 0 END) AS "Shortfall",
    ROUND(SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS "SOP %",
    CASE
        WHEN SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) >= 80 THEN 'A'
        WHEN SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) >= 60 THEN 'B'
        WHEN SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / COUNT(*) >= 40 THEN 'C'
        ELSE 'D'
    END AS "Grade"
FROM "Followups"
WHERE "Is_Excluded" = 'No'
  AND "SOP_Result" NOT IN ('SKIP', 'NO NUMBER')
GROUP BY "Lead Source_2"
ORDER BY COUNT(*) DESC


--- QUERY 4: STATUS WISE SOP ---
Name: Status_SOP
Paste:

SELECT
    "Followup Status" AS "Status",
    COUNT(*) AS "Total",
    SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) AS "PASS",
    SUM(CASE WHEN "SOP_Result" = 'FAIL' THEN 1 ELSE 0 END) AS "FAIL",
    ROUND(SUM(CASE WHEN "SOP_Result" = 'PASS' THEN 1 ELSE 0 END) * 100.0 / NULLIF(SUM(CASE WHEN "SOP_Result" IN ('PASS', 'FAIL') THEN 1 ELSE 0 END), 0), 1) AS "SOP %",
    CASE
        WHEN "Status_Type" = 'RINGING' THEN 'Day1=3, Day2-5=2/day'
        WHEN "Status_Type" = 'CALL_LATER' THEN 'Day1=2, Day2-5=1/day'
        WHEN "Status_Type" IN ('INVALID', 'PROSPECT', 'DIDNT_CONNECT') THEN '1 call daily'
        WHEN "Status_Type" = 'SKIP' THEN 'No SOP'
        ELSE 'Scheduled'
    END AS "SOP Rule"
FROM "Followups"
WHERE "Is_Excluded" = 'No'
GROUP BY "Followup Status", "Status_Type"
ORDER BY COUNT(*) DESC


--- QUERY 5: FAIL LIST ---
Name: SOP_Fail_List
Paste:

SELECT
    "Last Name" AS "Name",
    "Followup Owner" AS "Agent",
    "Lead Source_2" AS "Source",
    "Followup Status" AS "Status",
    "Biz_Days" AS "Biz Days",
    "Total Calls" AS "Calls Done",
    "Required_Calls" AS "Required",
    "Required_Calls" - "Total Calls" AS "Shortfall"
FROM "Followups"
WHERE "SOP_Result" = 'FAIL'
  AND "Is_Excluded" = 'No'
ORDER BY "Required_Calls" - "Total Calls" DESC


