STEP 2: FORMULA COLUMNS (8 Formulas)
============================================
Followups Table → Add Column → Formula Column
Naam likho → Formula paste karo → Save


--- FORMULA 1 ---
Name: Created_After_530
Formula:

if(hour("Created Time") > 17, 'Yes', if(hour("Created Time") = 17 and minute("Created Time") >= 30, 'Yes', 'No'))


--- FORMULA 2 ---
Name: SOP_Date
Formula:

if("Created_After_530" = 'Yes', adddate(datevalue("Created Time"), 1), datevalue("Created Time"))


--- FORMULA 3 ---
Name: Biz_Days
Formula:

datediff(today(), "SOP_Date") - floor(datediff(today(), "SOP_Date") / 7)


--- FORMULA 4 ---
Name: Status_Type
Formula:

if("Followup Status" = 'Ringing/Busy', 'RINGING', if("Followup Status" = 'Call Later', 'CALL_LATER', if("Followup Status" = 'Invalid Number', 'INVALID', if("Followup Status" in ('Prospect', 'Interested'), 'PROSPECT', if("Followup Status" = 'Didn''t Connect', 'DIDNT_CONNECT', if("Followup Status" in ('Lost Lead', 'Duplicate'), 'SKIP', if("Followup Status" = 'Contact In Future', 'SCHEDULED', 'OTHER')))))))


--- FORMULA 5 ---
Name: Required_Calls
Formula:

if("Status_Type" = 'RINGING', if("Biz_Days" <= 1, 3, 3 + ("Biz_Days" - 1) * 2), if("Status_Type" = 'CALL_LATER', if("Biz_Days" <= 1, 2, 2 + ("Biz_Days" - 1) * 1), if("Status_Type" in ('INVALID', 'PROSPECT', 'DIDNT_CONNECT', 'OTHER'), "Biz_Days", 0)))


--- FORMULA 6 ---
Name: Is_No_Number
Formula:

if("Phone" is null, 'Yes', 'No')


--- FORMULA 7 ---
Name: Is_Excluded
Formula:

if("Followup Owner" in ('Virat', 'Sandy', 'Leads'), 'Yes', 'No')


--- FORMULA 8 ---
Name: SOP_Result
Formula:

if("Is_Excluded" = 'Yes', 'EXCLUDED', if("Is_No_Number" = 'Yes', 'NO NUMBER', if("Status_Type" = 'SKIP', 'SKIP', if("Status_Type" = 'SCHEDULED', 'SCHEDULED', if("Upcoming Scheduled Call Date" >= now(), 'PASS', if("Total Calls" >= "Required_Calls", 'PASS', 'FAIL'))))))


